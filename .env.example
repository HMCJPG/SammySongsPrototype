# AWS S3 Configuration Template
# After you sign up for AWS and create a bucket, fill these in!

# 1. Bucket Name
# When you create a bucket on AWS, you'll give it a globally unique name (e.g., sammy-rabbit-assets-2026)
AWS_S3_BUCKET_NAME=

# 2. Region
# This is the geographical location of your bucket (e.g., us-east-1, us-west-2, eu-west-2 for London)
AWS_S3_REGION=

# 3. Access Keys
# You get these by creating an IAM User in AWS with "S3 Access" permissions. 
# NEVER commit the actual .env.local file to GitHub with these keys in it!
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 4. Public Base URL (Optional - if your bucket is set to "Public Read")
# Format generally looks like: https://[BUCKET-NAME].s3.[REGION].amazonaws.com
NEXT_PUBLIC_S3_BASE_URL=https://your-bucket-name.s3.your-region.amazonaws.com

# 5. NextAuth & Google OAuth Credentials
# Obtain Google credentials from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET= # generate using: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# 6. Firebase Initialization Config
# Found in Project Settings -> General -> Your apps -> SDK setup and configuration -> Config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDOXacw1P5Rs2AmhmxA7YLc4Wi4QLaHK3Q
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=bedtimestoriestesting.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=bedtimestoriestesting
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=bedtimestoriestesting.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=538539795451
NEXT_PUBLIC_FIREBASE_APP_ID=1:538539795451:web:c9ce6e7a82207c5116e15e
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-401F8L9VPQ
